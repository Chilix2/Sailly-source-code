# === SENSITIVE CREDENTIALS ===
# DO NOT commit this file. Store in Google Secret Manager instead.
# Template for local development only.

# XAI (Grok Realtime) API Key — for STS audio testing
# Generate at: https://console.x.ai/
# Cost: ~$0.05/min for audio
XAI_API_KEY=REDACTED_XAI_KEY

# Anthropic Claude API Key — for LLM reasoning
# Generate at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepGram API Key — for STT (speech-to-text)
# Generate at: https://console.deepgram.com/
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API Key — fallback for STS audio (if Grok unavailable)
# Generate at: https://platform.openai.com/
# Cost: ~$0.10/min for audio
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Cloud — Service Account (JSON path, loaded via GOOGLE_APPLICATION_CREDENTIALS)
# Store in GCP Secret Manager as base64-encoded JSON
GCP_SERVICE_ACCOUNT_JSON=/path/to/service-account-key.json

# === GOOGLE SECRET MANAGER REFERENCE ===
# To load from Google Secrets Manager:
#   export XAI_API_KEY=$(gcloud secrets versions access latest --secret="REDACTED_XAI_KEY")
#   export ANTHROPIC_API_KEY=$(gcloud secrets versions access latest --secret="anthropic-api-key")
#   export OPENAI_API_KEY=$(gcloud secrets versions access latest --secret="openai-api-key")
