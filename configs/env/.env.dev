# Sailly development environment — non-sensitive config only
# Secrets come from env vars when SAILLY_ENV=dev
SAILLY_ENV=dev
LOG_LEVEL=DEBUG
GCP_PROJECT_ID=sailly-voice-agent-eu
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://sailly:sailly@localhost:5432/sailly_dev
ENABLE_STT=true
ENABLE_TTS=true
ENABLE_TWILIO=false
DEMO_PORT=8080
DEFAULT_TENANT_ID=doboo
