# Sailly production environment — all secrets from Google Secret Manager
SAILLY_ENV=prod
LOG_LEVEL=WARNING
GCP_PROJECT_ID=sailly-prod
REDIS_URL=rediss://default:__from_gsm__@redis-prod.internal:6379
DATABASE_URL=postgresql://sailly:__from_gsm__@postgres-prod.internal:5432/sailly
ENABLE_STT=true
ENABLE_TTS=true
ENABLE_TWILIO=true
DEMO_PORT=8080
DEFAULT_TENANT_ID=doboo
SLACK_ALERTS_WEBHOOK=__from_gsm__
