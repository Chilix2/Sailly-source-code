# === LLM: Claude Haiku 4.5 via Vertex AI (EU multi-region, unlimited quota) ===
# Auth uses GOOGLE_APPLICATION_CREDENTIALS service account — no AWS keys needed.
# region="eu" = multi-region EU endpoint (dynamic routing across EU, high availability)
# Data stays in EU; routes via aiplatform.eu.rep.googleapis.com
VERTEX_LLM_REGION=eu
MAIN_LLM_MODEL=claude-haiku-4-5@20251001
SLOT_EXTRACTOR_MODEL=claude-haiku-4-5@20251001

# === TTS: Gemini Flash TTS via Vertex AI (unchanged) ===
TTS_ENGINE=gemini-flash
GOOGLE_APPLICATION_CREDENTIALS=/home/charles2/.ssh/sailly-voice-agent-key.json
GOOGLE_CLOUD_PROJECT=sailly-voice-agent-eu

# === GSM / production ===
# SAILLY_ENV=prod
