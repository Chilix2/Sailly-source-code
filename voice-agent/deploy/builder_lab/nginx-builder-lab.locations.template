# Inactive nginx template for a future Builder Lab host.
# Do not copy into /etc/nginx until a lab hostname and auth boundary are approved.

upstream sailly_builder_lab_backend {
    server 127.0.0.1:18080;
}

upstream sailly_builder_lab_dashboard {
    server 127.0.0.1:13001;
}

# Example locations for a dedicated lab server block such as builder-lab.sailly.tech.
# These intentionally do not change production /api, /api/builder, or /ws routes.

location = /ws/demo {
    proxy_pass http://sailly_builder_lab_backend/ws/demo;
    proxy_buffering off;
    proxy_request_buffering off;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;
    proxy_connect_timeout 60s;
}

location /api/builder/ {
    proxy_pass http://sailly_builder_lab_backend/api/builder/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

location / {
    proxy_pass http://sailly_builder_lab_dashboard;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}
