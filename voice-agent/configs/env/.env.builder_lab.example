# Sailly Builder Lab environment - non-sensitive template.
# Copy to .env.builder_lab in a lab clone or working tree and fill secrets locally.

SAILLY_ENV=builder_lab
LOG_LEVEL=DEBUG

# Keep the lab backend off live ports:
# - live browser-demo backend: 8080
# - live dashboard: 3001
# - production/stale voice routes: 3003
DEMO_PORT=18080
SERVER_URL=http://127.0.0.1:18080

# Use a lab tenant namespace so Redis session/live-trace keys are separated.
DEFAULT_TENANT_ID=builder_lab_doboo

# Use a separate Postgres database. Create it explicitly before running the lab.
DATABASE_URL=postgresql://sailly_lab:change_me@localhost:5432/sailly_builder_lab

# Use a separate Redis logical DB and lab-prefixed monitor keys.
REDIS_URL=redis://localhost:6379/14
MONITOR_REDIS_ENABLE=1
MONITOR_REDIS_LIST_KEY=builder_lab:monitor:completed_calls
MONITOR_CONFIG_REDIS_KEY=builder_lab:monitor:config
LIVE_TRACE_ENABLE=1

# Lab safety defaults: no real telephony/SMS side effects.
ENABLE_TWILIO=false
SMS_DRY_RUN=true

# Provider configuration. Prefer local shell exports or a private env file for secrets.
GCP_PROJECT_ID=sailly-voice-agent-eu
GOOGLE_PROJECT_ID=sailly-voice-agent-eu
GOOGLE_CLOUD_PROJECT=sailly-voice-agent-eu
GOOGLE_APPLICATION_CREDENTIALS=/home/charles2/.ssh/sailly-voice-agent-key.json
VERTEX_LLM_REGION=eu
MAIN_LLM_MODEL=claude-haiku-4-5@20251001
SLOT_EXTRACTOR_MODEL=claude-haiku-4-5@20251001
TTS_ENGINE=gemini-flash
ENABLE_STT=true
ENABLE_TTS=true

# Fill these outside git.
DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENAI_API_KEY=
ADMIN_API_TOKEN=
MONITOR_ADMIN_TOKEN=

# Validation/caller-bot defaults for the lab backend.
SAILLY_WS_URL=ws://127.0.0.1:18080/ws/headless
SAILLY_HEALTH_URL=http://127.0.0.1:18080/healthz
