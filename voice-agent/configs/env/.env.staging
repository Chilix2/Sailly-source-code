# Sailly staging environment — secrets loaded from Google Secret Manager
SAILLY_ENV=staging
LOG_LEVEL=INFO
GCP_PROJECT_ID=sailly-staging
REDIS_URL=rediss://default:__from_gsm__@redis-staging.internal:6379
DATABASE_URL=postgresql://sailly:__from_gsm__@postgres-staging.internal:5432/sailly
ENABLE_STT=true
ENABLE_TTS=true
ENABLE_TWILIO=true
DEMO_PORT=8080
DEFAULT_TENANT_ID=doboo
SLACK_ALERTS_WEBHOOK=__from_gsm__
