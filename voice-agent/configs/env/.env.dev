# Sailly development environment — non-sensitive config only
# Secrets come from env vars when SAILLY_ENV=dev
# Required secret env vars are loaded outside this file:
# - ANTHROPIC_API_KEY / ANTHROPIC_VERTEX_*
# - DEEPGRAM_API_KEY
# - GOOGLE_MAPS_API_KEY or MAPS_API_KEY
# - GOOGLE_APPLICATION_CREDENTIALS
# - TWILIO_* and WHATSAPP_* for telephony/SMS paths
# Keep real secret values out of this tracked file.
SAILLY_ENV=dev
LOG_LEVEL=DEBUG
GCP_PROJECT_ID=sailly-voice-agent-eu
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://sailly:sailly@localhost:5432/sailly_dev
ENABLE_STT=true
ENABLE_TTS=true
ENABLE_TWILIO=false
DEMO_PORT=8080
DEFAULT_TENANT_ID=doboo
