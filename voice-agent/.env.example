# Sanitized voice-agent environment template.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_CLOUD_PROJECT=sailly-voice-agent-eu
VERTEX_LLM_REGION=us-east5
DEMO_PORT=8080
DEEPGRAM_API_KEY=<DEEPGRAM_API_KEY>
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=<TWILIO_AUTH_TOKEN>
TWILIO_PHONE_NUMBER=+10000000000
GOOGLE_MAPS_API_KEY=your_google_maps_key_here
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://user:password@localhost:5432/sailly
SERVER_URL=https://your-domain.example
