{
  "schema_version": "1.0",
  "purpose": "Structured evidence index for Codex audit. Evidence pointers are not verdicts.",
  "scope": {
    "phases": ["A", "B", "C", "D", "F", "G", "H", "I"],
    "treat_validation_as": "evidence_under_audit",
    "raw_evidence_authority": "postgres",
    "artifact_cache": "/tmp/scenario_validation"
  },
  "runtime_contract": {
    "service_command": "venv/bin/python3 -m uvicorn server.main:app --host 0.0.0.0 --port 8080",
    "port": 8080,
    "health_endpoint_canonical": "/health",
    "headless_websocket": "ws://127.0.0.1:8080/ws/headless",
    "postgres_port": 5432,
    "redis_port": 6379,
    "known_drift": [
      "server/main.py currently exposes /healthz",
      "VALIDATION_RUN_CONFIG.md references /healthz",
      "fix_applier.py defaults to /health"
    ]
  },
  "models": {
    "caller": "grok-3-mini",
    "auditor": "grok-4-1-fast-non-reasoning",
    "fixer": "claude-haiku-4-5",
    "external_auditor": "gpt-5.5"
  },
  "locked_run_parameters": {
    "workers": 5,
    "stagger_s": 3,
    "max_attempts": 8,
    "output_dir": "/tmp/scenario_validation",
    "resume_default": true
  },
  "required_files": {
    "contract": [
      "VALIDATION_RUN_CONFIG.md",
      "AGENTS.md",
      "CODEX_RUNBOOK.md",
      "docs/phase_architecture.md",
      "docs/audit_plan.md"
    ],
    "validation": [
      "server/validation/AGENTS.md",
      "server/validation/scenario_based_loop.py",
      "server/validation/phase_runner.py",
      "server/validation/scenario_generator.py",
      "server/validation/grok_auditor_integration.py",
      "server/validation/haiku_fix_generator.py",
      "server/validation/fix_applier.py",
      "server/validation/postgres_metrics_fetcher.py",
      "server/validation/known_issues_advisor.py",
      "server/validation/known_issues.json"
    ],
    "product": [
      "server/brain/AGENTS.md",
      "server/brain/v4_pipeline.py",
      "server/brain/conversation_state.py",
      "server/brain/context_doc_builder.py",
      "server/brain/v4_turn_processor.py",
      "server/brain/layer1/text_mode_runner.py",
      "tools/executor.py",
      "configs/tenants/doboo.yaml",
      "server/main.py"
    ]
  },
  "claims_to_verify": [
    {
      "claim": "62/63 batches meet pass criteria",
      "evidence": ["/tmp/scenario_validation/batch_result_*.json", "postgres transcripts"],
      "status": "unverified"
    },
    {
      "claim": "H2.1_D2 is the only failing batch",
      "evidence": ["latest H2.1_D2 batch result", "postgres transcripts"],
      "status": "unverified"
    },
    {
      "claim": "H2.2_D3 advanced by pass rate despite low composite",
      "evidence": ["latest H2.2_D3 batch result", "postgres transcripts"],
      "status": "unverified"
    },
    {
      "claim": "I1.2_D4 has all scenario passes but low composite",
      "evidence": ["latest I1.2_D4 batch result", "postgres transcripts"],
      "status": "unverified"
    }
  ],
  "suspicious_batches": [
    {
      "batch": "H2.1_D2",
      "reason": "reported failing after rerun; discount-request scenario"
    },
    {
      "batch": "H2.2_D3",
      "reason": "advanced by pass rate while composite stayed low"
    },
    {
      "batch": "I1.2_D4",
      "reason": "all scenario passes but Grok flow/composite low"
    }
  ],
  "audit_questions": [
    "Is the runtime contract internally consistent?",
    "Is port 8080 running fresh code?",
    "Do result artifacts match Postgres transcripts?",
    "Which batches are truly failing versus force-advanced or stale?",
    "Are known issues current or self-reinforcing stale advice?",
    "Are findings product bugs, harness bugs, caller-bot drift, or scorer bugs?"
  ]
}

