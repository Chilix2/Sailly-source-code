[Unit]
Description=Sailly Voice Agent
After=network.target

[Service]
Type=simple
User=charles2
WorkingDirectory=/opt/sailly/voice-agent
EnvironmentFile=/opt/sailly/voice-agent.env
ExecStart=/opt/sailly/voice-agent/venv/bin/python3 -m uvicorn server.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
